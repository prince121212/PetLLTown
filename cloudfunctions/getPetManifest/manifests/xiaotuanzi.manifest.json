    { "id": "sleep-loop", "type": "loop", "label": "睡眠循环", "fps": 15, "next": ["sleep-loop", "sleep-exit"], "videoUrls": [] },
    { "id": "sleep-exit", "type": "transition", "label": "唤醒过渡", "fps": 15, "next": ["idle"], "videoUrls": [] }
