.alpha-video-container {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  overflow: hidden;
}

.alpha-canvas {
  width: 100%;
  height: 100%;
  background: transparent;
  display: block;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
}

.source-video {
  position: absolute;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

.source-video-debug {
  position: absolute;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}
