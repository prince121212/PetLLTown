<view class="alpha-video-container">
  <canvas
    id="{{canvasId}}"
    class="alpha-canvas"
    type="2d"
  ></canvas>
  <video
    id="sourceVideo"
    class="source-video-debug"
    src="{{src}}"
    autoplay="{{autoplay}}"
    loop="{{loop}}"
    muted="{{true}}"
    controls="{{false}}"
    show-center-play-btn="{{false}}"
    show-play-btn="{{false}}"
    show-fullscreen-btn="{{false}}"
    enable-progress-gesture="{{false}}"
    object-fit="contain"
  ></video>
</view>
