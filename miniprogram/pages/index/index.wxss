page {
  height: 100%;
  overflow: hidden;
  background: #000;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.app,
.page {
  position: relative;
  width: 100%;
  height: 100%;
  color: #f8fbff;
  overflow: hidden;
}

.safe,
.picker-safe {
  box-sizing: border-box;
  height: 100%;
}

.safe {
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  gap: 24rpx;
  padding: var(--safe-top, 92rpx) 28rpx calc(28rpx + env(safe-area-inset-bottom));
}

.top,
.picker-head {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 58rpx;
}

.pet-title {
  display: grid;
  gap: 10rpx;
  min-width: 0;
}

.title,
.page-title {
  color: #f8fbff;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.12;
}

.subtitle {
  color: rgba(248, 251, 255, 0.66);
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.35;
}

.tiny-btn,
.tiny-placeholder {
  width: 58rpx;
  height: 58rpx;
  border-radius: 15rpx;
}

.tiny-btn {
  display: grid;
  place-items: center;
  padding: 0;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: #f8fbff;
  font-size: 28rpx;
  box-shadow: 0 15rpx 38rpx rgba(0, 0, 0, 0.18);
}

.back-btn {
  position: absolute;
  left: -4rpx;
  top: 50%;
  z-index: 2;
  width: 72rpx;
  height: 72rpx;
  display: grid;
  place-items: center;
  color: #f8fbff;
  transform: translateY(-50%);
}

.back-icon {
  display: block;
  width: 60rpx;
  height: 60rpx;
  color: #f8fbff;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 60rpx;
  text-align: center;
}

.home-page {
  background: #000;
  position: relative;
}

.home-wallpaper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.home-page .safe {
  position: relative;
  display: block;
  padding: 0;
  z-index: 1;
}

.home-page .top {
  position: absolute;
  left: 42rpx;
  width: 230rpx;
  z-index: 16;
  min-height: 78rpx;
}

.home-page .settings-entry {
  position: absolute;
  top: -2rpx;
  left: 50%;
  right: auto;
  z-index: 17;
  width: 324rpx;
  height: 52rpx;
  transform: translateX(-50%);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.18);
  color: rgba(248, 251, 255, 0.82);
  font-size: 22rpx;
}

.home-page .stage {
  position: absolute;
  left: 0;
  right: 0;
  top: calc(var(--safe-top, 92rpx) + 86rpx);
  bottom: calc(238rpx + env(safe-area-inset-bottom));
  z-index: 11;
  display: grid;
  place-items: end center;
  min-height: 0;
  padding: 0;
}

.home-page .pet-canvas,
.home-page .pet-frame,
.home-page alpha-video {
  width: 630rpx;
  height: 880rpx;
  max-width: none;
  background: transparent;
}

.home-page .pet-frame {
  position: absolute;
}

.home-page .listen-area {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 15;
  display: grid;
  place-items: center;
  gap: 16rpx;
  min-height: 222rpx;
  padding: 0;
}

.listen-orb {
  width: 169rpx;
  height: 169rpx;
  display: grid;
  place-items: center;
  overflow: hidden;
  border-radius: 999rpx;
  background: #07101b;
  box-shadow: 0 27rpx 65rpx rgba(25, 39, 56, 0.22), inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.listen-orb.recording {
  box-shadow: 0 0 0 10rpx rgba(118, 150, 255, 0.12), 0 36rpx 86rpx rgba(87, 112, 255, 0.28);
}

.listen-orb.uploading,
.listen-orb.transcribing,
.listen-orb.thinking {
  opacity: 0.86;
}

.listen-orb.error {
  box-shadow: 0 0 0 8rpx rgba(255, 122, 122, 0.11), 0 34rpx 72rpx rgba(0, 0, 0, 0.28);
}

.listen-video {
  width: 169rpx;
  height: 169rpx;
  display: block;
  pointer-events: none;
}

.voice-hint,
.voice-text,
.pet-reply {
  max-width: 620rpx;
  color: rgba(248, 251, 255, 0.66);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
}

.voice-text {
  color: rgba(248, 251, 255, 0.9);
}

.pet-reply {
  max-width: 640rpx;
  padding: 12rpx 22rpx;
  border-radius: 15rpx;
  background: rgba(255, 255, 255, 0.09);
  color: #f8fbff;
  font-size: 25rpx;
}

.settings-page {
  background: linear-gradient(180deg, #283645 0%, #485866 54%, #efe2d1 100%);
}

.settings-page .safe {
  grid-template-rows: auto minmax(0, 1fr);
  gap: 24rpx;
  padding-top: var(--nav-top, 92rpx);
  padding-left: 34rpx;
  padding-right: 34rpx;
}

.settings-page .top {
  min-height: var(--nav-height, 58rpx);
  justify-content: center;
  margin-bottom: var(--nav-content-gap, 44rpx);
}

.settings-page .page-title,
.picker-head .page-title {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 100%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.settings-main {
  box-sizing: border-box;
  width: 100%;
  min-height: 0;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  align-content: start;
  justify-items: stretch;
  gap: 24rpx;
}

.pet-card {
  box-sizing: border-box;
  width: 100%;
  min-height: 166rpx;
  display: grid;
  grid-template-columns: 131rpx 1fr;
  align-items: center;
  gap: 23rpx;
  padding: 23rpx;
  border: 1rpx solid rgba(24, 32, 42, 0.08);
  border-radius: 15rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #17202a;
  box-shadow: 0 19rpx 50rpx rgba(30, 34, 39, 0.08);
}

.pet-thumb {
  width: 119rpx;
  height: 119rpx;
}

.pet-card-name {
  color: #17202a;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.2;
}

.setting-list {
  box-sizing: border-box;
  min-height: 0;
  display: grid;
  align-content: start;
  justify-items: stretch;
  gap: 18rpx;
  width: 100%;
}

.setting-row {
  box-sizing: border-box;
  width: 100%;
  max-width: none;
  min-height: 112rpx;
  display: grid;
  grid-template-columns: 65rpx 1fr auto;
  align-items: center;
  gap: 19rpx;
  padding: 19rpx 23rpx;
  border: 1rpx solid rgba(24, 32, 42, 0.08);
  border-radius: 15rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #17202a;
  text-align: left;
}

.setting-icon {
  width: 65rpx;
  height: 65rpx;
  display: grid;
  place-items: center;
  border-radius: 15rpx;
  background: #edf2ec;
  color: #4f7d53;
  font-size: 31rpx;
}

.setting-copy {
  display: grid;
  gap: 8rpx;
  min-width: 0;
  text-align: left;
}

.setting-title {
  color: #17202a;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.2;
}

.setting-subtitle {
  color: #6c7682;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.4;
}

.chevron {
  color: rgba(23, 32, 42, 0.42);
  font-size: 35rpx;
  font-weight: 700;
}

.switch {
  width: 81rpx;
  height: 46rpx;
  display: flex;
  justify-content: flex-start;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #dfe7dd;
}

.switch.active {
  justify-content: flex-end;
}

.switch-dot {
  width: 35rpx;
  height: 35rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 6rpx 15rpx rgba(35, 42, 50, 0.16);
}

.mini-ad {
  box-sizing: border-box;
  width: 100%;
  display: grid;
  gap: 8rpx;
  padding: 18rpx 23rpx;
  border: 1rpx solid rgba(24, 32, 42, 0.08);
  border-radius: 15rpx;
  background: rgba(255, 255, 255, 0.74);
  color: #17202a;
}

.mini-ad-title {
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.mini-ad-copy {
  color: #6c7682;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.35;
}

.picker-page {
  background: #000;
}

.picker-safe {
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto auto;
  gap: 18rpx;
  padding: var(--nav-top, 92rpx) 60rpx calc(70rpx + env(safe-area-inset-bottom));
}

.picker-head {
  min-height: var(--nav-height, 58rpx);
  justify-content: center;
  margin-bottom: var(--nav-content-gap, 44rpx);
}

.pet-swiper {
  min-height: 0;
  height: 100%;
  border-left: 1rpx solid rgba(255, 255, 255, 0.1);
  border-right: 1rpx solid rgba(255, 255, 255, 0.1);
}

.pet-option {
  box-sizing: border-box;
  height: 100%;
  display: grid;
  grid-template-rows: minmax(0, 1fr) auto auto;
  gap: 12rpx;
  padding: 36rpx 18rpx 24rpx;
  background: #000;
  color: #f8fbff;
}

.pet-photo {
  min-height: 0;
  display: grid;
  place-items: center;
  overflow: hidden;
  background: #000;
}

.picker-pet {
  width: 92%;
  height: 78%;
}

.picker-name {
  color: #f8fbff;
  font-size: 35rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
}

.picker-subtitle {
  color: rgba(248, 251, 255, 0.62);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
  text-align: center;
}

.picker-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
}

.dot.active {
  width: 35rpx;
  background: rgba(255, 255, 255, 0.78);
}

.select-btn {
  width: 336rpx;
  min-height: 76rpx;
  display: grid;
  place-items: center;
  justify-self: center;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 12rpx;
  background: rgba(245, 245, 245, 0.94);
  color: #1d2731;
  font-size: 24rpx;
  font-weight: 800;
}
