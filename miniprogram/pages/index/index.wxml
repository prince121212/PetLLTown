<view class="app">
  <view class="page home-page {{pageName === 'home' ? '' : 'home-page-paused'}}">
    <video
      wx:if="{{backgroundMediaKind === 'video' && backgroundMediaUrl}}"
      class="home-wallpaper"
      src="{{backgroundMediaUrl}}"
      autoplay="{{true}}"
      loop="{{true}}"
      muted="{{true}}"
      controls="{{false}}"
      show-center-play-btn="{{false}}"
      show-play-btn="{{false}}"
      show-fullscreen-btn="{{false}}"
      enable-progress-gesture="{{false}}"
      object-fit="cover"
    ></video>
    <image wx:elif="{{backgroundMediaKind === 'image' && backgroundMediaUrl}}" class="home-wallpaper" src="{{backgroundMediaUrl}}" mode="aspectFill" show-menu-by-longpress="{{false}}" />
    <view class="safe" style="{{pageShellStyle}}">
      <view class="top" style="{{homeTopStyle}}">
        <view class="pet-title">
          <text class="title">{{petName}}</text>
          <text class="subtitle">{{homeHint}}</text>
        </view>
      </view>

      <view class="status-drawer {{drawerOpen ? 'open' : 'closed'}}">
        <view class="drawer-content">
          <button class="drawer-settings-btn" bindtap="openSettings">⚙</button>
          <view class="drawer-stats">
            <view class="drawer-stat-row">
              <text class="drawer-stat-icon">⚡</text>
              <view class="drawer-stat-bar"><view class="drawer-stat-fill energy" style="width:{{statEnergy}}%"></view></view>
            </view>
            <view class="drawer-stat-row">
              <text class="drawer-stat-icon">💛</text>
              <view class="drawer-stat-bar"><view class="drawer-stat-fill affection" style="width:{{statAffection}}%"></view></view>
            </view>
          </view>
          <view class="drawer-relationship">
            <text class="drawer-flame">{{relationshipIcon}}</text>
            <text class="drawer-streak">{{relationshipText}}</text>
          </view>
          <text class="drawer-mood">{{moodIcon}} {{moodText}}</text>
        </view>
        <view class="drawer-tab" bindtap="toggleDrawer">{{drawerOpen ? '‹' : '›'}}</view>
      </view>

      <view class="stage" style="{{homeStageStyle}}" aria-label="宠物主舞台">
        <view wx:if="{{!configReady}}" class="pet-loading">
          <view class="pet-loading-spinner"></view>
        </view>
        <canvas id="petVideoCanvas" type="webgl" class="pet-canvas"></canvas>
      </view>

      <view class="listen-area" aria-label="语音监听状态">
        <text class="voice-hint">{{voiceHint}}</text>
        <text wx:if="{{transcribedText}}" class="voice-text">{{transcribedText}}</text>
        <text wx:if="{{petReply}}" class="pet-reply">{{petReply}}</text>
        <view
          class="listen-orb {{voiceStatus}} {{orbPressed ? 'pressed' : ''}}"
          bindtouchstart="handleListenTouchStart"
          bindtouchend="handleListenTouchEnd"
          bindtouchcancel="handleListenTouchEnd"
        >
          <video
            class="listen-video"
            src="{{listenOrbVideoUrl}}"
            autoplay="{{true}}"
            loop="{{true}}"
            muted="{{true}}"
            controls="{{false}}"
            show-center-play-btn="{{false}}"
            show-play-btn="{{false}}"
            show-fullscreen-btn="{{false}}"
            enable-progress-gesture="{{false}}"
            object-fit="cover"
            catchtouchstart="handleListenTouchStart"
            catchtouchend="handleListenTouchEnd"
            catchtouchcancel="handleListenTouchEnd"
          ></video>
        </view>
      </view>
    </view>

    <!-- 右侧调试面板 -->
    <view class="debug-toggle" bindtap="toggleDebug">{{debugOpen ? '✕' : '🔍'}}</view>
    <view wx:if="{{debugOpen}}" class="debug-panel">
      <view class="debug-section">
        <text class="debug-title">播放队列</text>
        <view class="debug-queue">
          <text wx:for="{{debugQueue}}" wx:key="*this" class="debug-queue-item {{index === 0 ? 'active' : ''}}">{{item}}</text>
        </view>
      </view>
      <view class="debug-section">
        <text class="debug-title">主人画像</text>
        <text class="debug-text">{{debugPortrait || '（空）'}}</text>
      </view>
      <view class="debug-section">
        <text class="debug-title">画像状态</text>
        <view class="debug-meta">
          <text class="debug-text">本轮触发：{{debugPortraitTriggered ? '是' : '否'}}</text>
          <text class="debug-text">本轮更新：{{debugPortraitUpdated ? '是' : '否'}}</text>
          <text class="debug-text">累计计数：{{debugPortraitMemoryCount}}</text>
          <text class="debug-text">记忆来源：{{debugMemorySource || '（无）'}}</text>
          <text class="debug-text">解析模式：{{debugMemoryParseMode || '（无）'}}</text>
        </view>
      </view>
      <view class="debug-section">
        <text class="debug-title">短期记忆 ({{debugMemories.length}})</text>
        <view class="debug-memories">
          <text wx:for="{{debugMemories}}" wx:key="*this" class="debug-memory-item">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{pageName === 'settings'}}" class="page settings-page">
    <view class="safe" style="{{pageShellStyle}}">
      <view class="top centered">
        <view class="back-btn" aria-label="返回首页" bindtap="backHome">
          <text class="back-icon">‹</text>
        </view>
        <text class="page-title">设置</text>
        <view class="tiny-placeholder"></view>
      </view>

      <view class="settings-main">
        <view class="pet-card">
          <image class="pet-thumb" src="{{settingsThumb}}" mode="aspectFit" />
          <text class="pet-card-name">{{petName}}</text>
        </view>

        <view class="setting-list">
          <block wx:for="{{settings}}" wx:key="id">
            <view
              class="setting-row"
              data-target="{{item.target}}"
              bindtap="handleSettingTap"
              aria-label="{{item.title}}"
            >
              <view class="setting-icon">{{item.icon}}</view>
              <view class="setting-copy">
                <text class="setting-title">{{item.title}}</text>
                <text class="setting-subtitle">{{item.subtitle}}</text>
              </view>
              <view wx:if="{{item.kind === 'switch'}}" class="switch {{item.enabled ? 'active' : ''}}">
                <view class="switch-dot"></view>
              </view>
              <view wx:else class="chevron">›</view>
            </view>
          </block>
        </view>

        <view wx:if="{{miniAd.enabled}}" class="mini-ad">
          <text class="mini-ad-title">{{miniAd.title}}</text>
          <text class="mini-ad-copy">{{miniAd.copy}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{pageName === 'petPicker'}}" class="page picker-page">
    <view class="picker-safe" style="{{pageShellStyle}}">
      <view class="picker-head">
        <view class="back-btn" aria-label="返回设置" bindtap="backSettings">
          <text class="back-icon">‹</text>
        </view>
        <text class="page-title">更换宠物</text>
        <view class="tiny-placeholder"></view>
      </view>

      <swiper
        class="pet-swiper"
        circular="{{false}}"
        previous-margin="28rpx"
        next-margin="28rpx"
        current="{{activePetIndex}}"
        bindchange="handlePetChange"
      >
        <block wx:for="{{pickerPets}}" wx:key="id">
          <swiper-item>
            <view class="pet-option">
              <view class="pet-photo">
                <image class="picker-pet" src="{{item.frame}}" mode="aspectFit" show-menu-by-longpress="{{false}}" />
              </view>
              <text class="picker-name">{{item.name}}</text>
              <text class="picker-subtitle">{{item.subtitle}}</text>
            </view>
          </swiper-item>
        </block>
      </swiper>

      <view class="picker-dots">
        <block wx:for="{{pets}}" wx:key="id">
          <view class="dot {{index === activePetIndex ? 'active' : ''}}"></view>
        </block>
      </view>

      <button class="select-btn" bindtap="selectPet">选择它</button>
    </view>
  </view>

  <view wx:if="{{pageName === 'roomPicker'}}" class="page picker-page">
    <view class="picker-safe" style="{{pageShellStyle}}">
      <view class="picker-head">
        <view class="back-btn" aria-label="返回设置" bindtap="backSettings">
          <text class="back-icon">‹</text>
        </view>
        <text class="page-title">更换房间</text>
        <view class="tiny-placeholder"></view>
      </view>

      <swiper
        class="pet-swiper"
        circular="{{false}}"
        previous-margin="28rpx"
        next-margin="28rpx"
        current="{{activeRoomIndex}}"
        bindchange="handleRoomChange"
      >
        <block wx:for="{{pickerRooms}}" wx:key="id">
          <swiper-item>
            <view class="pet-option">
              <view class="pet-photo room-photo">
                <video
                  wx:if="{{item.kind === 'video'}}"
                  class="picker-room"
                  src="{{item.previewUrl}}"
                  autoplay="{{true}}"
                  loop="{{true}}"
                  muted="{{true}}"
                  controls="{{false}}"
                  show-center-play-btn="{{false}}"
                  show-play-btn="{{false}}"
                  show-fullscreen-btn="{{false}}"
                  enable-progress-gesture="{{false}}"
                  object-fit="cover"
                ></video>
                <image wx:else class="picker-room" src="{{item.previewUrl}}" mode="aspectFill" show-menu-by-longpress="{{false}}" />
              </view>
              <text class="picker-name">{{item.name}}</text>
              <text class="picker-subtitle">{{item.subtitle}}</text>
            </view>
          </swiper-item>
        </block>
      </swiper>

      <view class="picker-dots">
        <block wx:for="{{rooms}}" wx:key="id">
          <view class="dot {{index === activeRoomIndex ? 'active' : ''}}"></view>
        </block>
      </view>

      <button class="select-btn" bindtap="selectRoom">选择它</button>
    </view>
  </view>
</view>
